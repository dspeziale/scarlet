# ─────────────────────────────────────────────────────────────────────────────
# SOC Seattle — Environment Variables
# Local dev: copy to .env  |  Vercel: set in Project Settings → Env Variables
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-use-python-secrets-token-hex-32

# ── Database (NeonDB) ─────────────────────────────────────────────────────────
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/soc_seattle?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-different-from-secret-key

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Omit or set to "memory://" on Vercel (serverless — no persistent Redis needed
# per instance). Use Redis on self-hosted multi-instance deployments.
# REDIS_URL=redis://default:password@host:6379

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins.
CORS_ORIGINS=https://your-app.vercel.app

# ── PCAP storage ─────────────────────────────────────────────────────────────
# On Vercel the filesystem is ephemeral (/tmp, max 512 MB, cleared per invocation).
# Uploads will succeed but downloads require the same Lambda instance still live.
# For persistent PCAP storage: mount an S3-compatible volume or use Vercel Blob.
# Leave unset → auto-detects Vercel (VERCEL=1) and falls back to /tmp/soc_pcap.
# PCAP_STORAGE_PATH=/mnt/pcap

# ── Security ──────────────────────────────────────────────────────────────────
FORCE_HTTPS=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Probe & crypto ────────────────────────────────────────────────────────────
PROBE_TOKEN_EXPIRY_HOURS=24
KEY_ROTATION_DAYS=30

# ── Local dev only ────────────────────────────────────────────────────────────
# TEST_DATABASE_URL=sqlite:///:memory:
# FLASK_ENV=development
# FORCE_HTTPS=false
# CORS_ORIGINS=http://localhost:5000
