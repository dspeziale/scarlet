{
  "version": 2,
  "builds": [
    {
      "src": "server/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server/app.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "FORCE_HTTPS": "true",
    "LOG_FORMAT": "json",
    "LOG_LEVEL": "INFO"
  },
  "regions": ["fra1"]
}
